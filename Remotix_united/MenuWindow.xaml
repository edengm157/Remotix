<Window x:Class="RemotixApp.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remotix - Select Mode" Height="450" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

	<Grid Margin="40">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<StackPanel>
			<TextBlock Text="Remotix" Foreground="White" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
			<TextBlock Text="Choose your mode" Foreground="#9CA3AF" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,0"/>
		</StackPanel>

		<UniformGrid Grid.Row="1" Columns="2" Margin="0,40,0,0">
			<Button x:Name="SenderButton" Click="SenderButton_Click" Margin="10" Background="#1F2937" BorderThickness="0" Cursor="Hand">
				<Button.Template>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="15">
							<Border.Effect>
								<DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
							</Border.Effect>
							<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
								<TextBlock Text="📤" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,20"/>
								<TextBlock Text="Start Sharing" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Broadcast this screen" Foreground="#6B7280" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
					</ControlTemplate>
				</Button.Template>
			</Button>

			<Button x:Name="ReceiverButton" Click="ReceiverButton_Click" Margin="10" Background="#1F2937" BorderThickness="0" Cursor="Hand">
				<Button.Template>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="15">
							<Border.Effect>
								<DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
							</Border.Effect>
							<StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
								<TextBlock Text="📥" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,20"/>
								<TextBlock Text="View Screen" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
								<TextBlock Text="Connect to a remote device" Foreground="#6B7280" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
					</ControlTemplate>
				</Button.Template>
			</Button>
		</UniformGrid>
	</Grid>
</Window>