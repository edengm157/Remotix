<Window x:Class="RemotixApp.SenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remotix Sender" Height="750" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

	<Window.Resources>
		<Style x:Key="MetricCard" TargetType="Border">
			<Setter Property="Background" Value="#1E293B"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="Padding" Value="15"/>
			<Setter Property="Margin" Value="5"/>
		</Style>
		<Style x:Key="MetricLabel" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#94A3B8"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="TextAlignment" Value="Center"/>
		</Style>
		<Style x:Key="MetricValue" TargetType="TextBlock">
			<Setter Property="Foreground" Value="#F8FAFC"/>
			<Setter Property="FontSize" Value="24"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
	</Window.Resources>

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid Grid.Row="0" Margin="0,0,0,20">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<StackPanel VerticalAlignment="Center">
				<TextBlock Text="Broadcasting" Foreground="White" FontSize="22" FontWeight="Bold"/>
				<TextBlock x:Name="StatusText" Text="Ready to capture" Foreground="#10B981" FontSize="14" Margin="0,5,0,0"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Orientation="Horizontal">
				<StackPanel Margin="0,0,20,0" VerticalAlignment="Center">
					<CheckBox x:Name="AdaptiveQualityCheckBox" Content="Adaptive Quality" Foreground="#E2E8F0" 
                              Checked="AdaptiveQuality_Changed" Unchecked="AdaptiveQuality_Changed"
                              VerticalContentAlignment="Center" FontSize="14" Margin="0,0,10,5"/>
					<ComboBox x:Name="QualityPresetComboBox" SelectionChanged="QualityPreset_Changed"
                              Width="150" Height="30" Background="#334155" Foreground="Black" BorderThickness="0">
						<ComboBoxItem Content="Ultra Quality" Tag="Ultra"/>
						<ComboBoxItem Content="High Quality" Tag="High"/>
						<ComboBoxItem Content="Medium Quality" Tag="Medium" IsSelected="True"/>
						<ComboBoxItem Content="Low Quality" Tag="Low"/>
						<ComboBoxItem Content="Very Low" Tag="VeryLow"/>
					</ComboBox>
				</StackPanel>

				<Button x:Name="StartButton" Click="StartButton_Click" Content="▶ START" Width="100" Height="40" 
                        Background="#10B981" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</Button.Resources>
				</Button>
				<Button x:Name="StopButton" Click="StopButton_Click" Content="⏹ STOP" Width="100" Height="40" 
                        Background="#EF4444" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="5" IsEnabled="False">
					<Button.Resources>
						<Style TargetType="Border">
							<Setter Property="CornerRadius" Value="8"/>
						</Style>
					</Button.Resources>
				</Button>
			</StackPanel>
		</Grid>

		<UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,20">
			<Border Style="{StaticResource MetricCard}">
				<StackPanel>
					<TextBlock Text="FPS" Style="{StaticResource MetricLabel}"/>
					<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
						<TextBlock x:Name="FpsText" Text="0.0" Style="{StaticResource MetricValue}"/>
						<TextBlock Text=" fps" Foreground="#64748B" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource MetricCard}">
				<StackPanel>
					<TextBlock Text="Bitrate" Style="{StaticResource MetricLabel}"/>
					<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
						<TextBlock x:Name="BitrateText" Text="0.0" Style="{StaticResource MetricValue}"/>
						<TextBlock Text=" Mbps" Foreground="#64748B" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource MetricCard}">
				<StackPanel>
					<TextBlock Text="Encode Time" Style="{StaticResource MetricLabel}"/>
					<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
						<TextBlock x:Name="LatencyText" Text="0" Style="{StaticResource MetricValue}"/>
						<TextBlock Text=" ms" Foreground="#64748B" FontSize="12" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource MetricCard}">
				<StackPanel>
					<TextBlock Text="Dropped Frames" Style="{StaticResource MetricLabel}"/>
					<StackPanel Orientation="Horizontal" Margin="0,5,0,0">
						<TextBlock x:Name="DroppedText" Text="0" Style="{StaticResource MetricValue}" Foreground="#F59E0B"/>
					</StackPanel>
				</StackPanel>
			</Border>

			<Border Style="{StaticResource MetricCard}">
				<StackPanel>
					<TextBlock Text="Quality" Style="{StaticResource MetricLabel}"/>
					<TextBlock x:Name="QualityIndicator" Text="🟢" FontSize="24" Margin="0,5,0,0"/>
				</StackPanel>
			</Border>
		</UniformGrid>

		<Border Grid.Row="2" Background="Black" CornerRadius="12" BorderBrush="#334155" BorderThickness="1" ClipToBounds="True">
			<Image x:Name="PreviewImage" Stretch="Uniform"/>
		</Border>

		<TextBlock Grid.Row="3" Text="Remotix Performance Monitor v2.0" Foreground="#475569" 
                   FontSize="12" HorizontalAlignment="Center" Margin="0,10,0,0"/>
	</Grid>
</Window>