<Window x:Class="ScreenCaptureApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Capture Sender - Performance Monitor" Height="700" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Control Panel -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="StartButton" Content="▶ Start Capture" 
                        Width="130" Height="35" Margin="5" 
                        Click="StartButton_Click"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" FontSize="13"/>
                <Button x:Name="StopButton" Content="⏹ Stop Capture" 
                        Width="130" Height="35" Margin="5" 
                        Click="StopButton_Click" IsEnabled="False"
                        Background="#E74C3C" Foreground="White"
                        FontWeight="Bold" FontSize="13"/>

                <Separator Width="20" Background="Transparent"/>

                <CheckBox x:Name="AdaptiveQualityCheckBox" 
                          Content="Adaptive Quality"
                          VerticalAlignment="Center" Margin="10,0"
                          Foreground="White" FontSize="12"
                          IsChecked="True"
                          Checked="AdaptiveQuality_Changed"
                          Unchecked="AdaptiveQuality_Changed"/>

                <ComboBox x:Name="QualityPresetComboBox" 
                          Width="120" Height="30" Margin="5"
                          SelectionChanged="QualityPreset_Changed"
                          FontSize="12">
                    <ComboBoxItem Content="Ultra Quality" Tag="Ultra"/>
                    <ComboBoxItem Content="High Quality" Tag="High"/>
                    <ComboBoxItem Content="Medium Quality" Tag="Medium" IsSelected="True"/>
                    <ComboBoxItem Content="Low Quality" Tag="Low"/>
                    <ComboBoxItem Content="Very Low" Tag="VeryLow"/>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Performance Metrics Panel -->
        <Border Grid.Row="1" Background="#34495E" Padding="10" Margin="0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- FPS -->
                <StackPanel Grid.Column="0" Margin="5,0">
                    <TextBlock Text="FPS" Foreground="#95A5A6" FontSize="10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FpsText" Text="0.0" 
                                   Foreground="#ECF0F1" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" fps" Foreground="#BDC3C7" FontSize="11" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bitrate -->
                <StackPanel Grid.Column="1" Margin="5,0">
                    <TextBlock Text="BITRATE" Foreground="#95A5A6" FontSize="10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="BitrateText" Text="0.0" 
                                   Foreground="#ECF0F1" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" Mbps" Foreground="#BDC3C7" FontSize="11" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    </StackPanel>
                </StackPanel>

                <!-- Latency -->
                <StackPanel Grid.Column="2" Margin="5,0">
                    <TextBlock Text="ENCODE TIME" Foreground="#95A5A6" FontSize="10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="LatencyText" Text="0" 
                                   Foreground="#ECF0F1" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" ms" Foreground="#BDC3C7" FontSize="11" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    </StackPanel>
                </StackPanel>

                <!-- Dropped Frames -->
                <StackPanel Grid.Column="3" Margin="5,0">
                    <TextBlock Text="DROPPED" Foreground="#95A5A6" FontSize="10" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="DroppedText" Text="0" 
                                   Foreground="#ECF0F1" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text=" frames" Foreground="#BDC3C7" FontSize="11" 
                                   VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                    </StackPanel>
                </StackPanel>

                <!-- Quality Indicator -->
                <StackPanel Grid.Column="4" Margin="15,0" VerticalAlignment="Center">
                    <TextBlock Text="QUALITY" Foreground="#95A5A6" FontSize="10" FontWeight="Bold" 
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="QualityIndicator" Text="🟢" 
                               FontSize="28" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Preview Area -->
        <Border Grid.Row="2" BorderBrush="#7F8C8D" BorderThickness="2" 
                Margin="10" Background="Black">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📊" FontSize="14" 
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="StatusText" Grid.Column="1" 
                           Text="Ready to capture" 
                           Foreground="#ECF0F1" FontSize="12"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>