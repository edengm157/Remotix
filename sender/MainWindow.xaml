<Window x:Class="ScreenCaptureApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Capture Display" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button x:Name="StartButton" Content="Start Capture" 
                    Width="120" Height="30" Margin="5" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="Stop Capture" 
                    Width="120" Height="30" Margin="5" Click="StopButton_Click" IsEnabled="False"/>
            <TextBlock x:Name="StatusText" Text="Ready" 
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="2" Margin="10">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</Window>